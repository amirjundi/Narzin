# ── Secrets / environment ─────────────────────────────
**/.env
**/.env.*
!**/.env.example

# ── Tooling output ────────────────────────────────────
graphify-out/

# ── PHP / Laravel ─────────────────────────────────────
# NOTE: anchored to Composer's vendor dir only. A bare "**/vendor/" also
# matches Modules/Vendor and Narzin-app/vendor on case-insensitive systems
# (Windows), which silently drops real source from the repo.
/narzinapp-main/vendor/
narzinapp-main/storage/*.key
narzinapp-main/public/storage
narzinapp-main/public/build/
# Laravel vendor-publish output (regenerated; the server keeps its own copy)
narzinapp-main/public/vendor/
narzinapp-main/resources/views/vendor/

# ── Node / web build ──────────────────────────────────
**/node_modules/
**/dist/
**/dist-ssr/

# ── Flutter / mobile build artifacts ──────────────────
**/build/
**/.dart_tool/
**/.cxx/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/*.apk
**/*.aab
**/*.keystore
**/*.jks
**/key.properties

# ── Backed-up nested git histories (from monorepo merge) ─
**/.git.bak/

# ── OS / editor ───────────────────────────────────────
.DS_Store
Thumbs.db
*.log
.idea/
.vscode/
