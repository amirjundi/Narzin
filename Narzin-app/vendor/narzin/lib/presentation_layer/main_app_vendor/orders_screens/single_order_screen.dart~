class StatusButton extends StatelessWidget {
  StatusButton({super.key, this.selectedItem});
  final GlobalKey _buttonKey = GlobalKey();
  final selectedItem;

  @override
  Widget build(BuildContext context) {
    return InkWell(
      key: _buttonKey, // Assign the GlobalKey to the InkWell
      onTap: () {
        // Get the render box of the button
        final RenderBox renderBox = _buttonKey.currentContext?.findRenderObject() as RenderBox;
        // Get the position of the button
        final Offset buttonPosition = renderBox.localToGlobal(Offset.zero);

        // Calculate the position for the menu
        final RelativeRect position = RelativeRect.fromLTRB(
          buttonPosition.dx, // Left
          buttonPosition.dy + renderBox.size.height, // Top
          buttonPosition.dx + renderBox.size.width, // Right
          buttonPosition.dy, // Bottom
        );

        showMenu(
          context: context,
          position: position, // Use the calculated position
          items: [
            ...Constants.orderItemStatus.map(
                  (e) => PopupMenuItem(
                child: Text(e),
                onTap: () async {
                  String token = BlocProvider.of<LoginCubit>(context).vendorData?.data?.token ?? '';
                  var res = await context.read<VendorStatsCubit>().changeOrderStatus(
                    token: token,
                    id: selectedItem?.id.toString() ?? '',
                    status: e,
                  );
                  if (res == null) {
                    context.read<VendorStatsCubit>().getOrders(token: token);
                    Navigator.canPop(context)?Navigator.pop(context):null;
                  }
                },
              ),
            ),
          ],
        );
      },
      child: Container(
        constraints: const BoxConstraints(minHeight: 40, minWidth: 90),
        decoration: BoxDecoration(
          color: Color(Constants.orderItemStatusColors[selectedItem?.status ?? ''] ?? 0xffF0A440),
          borderRadius: BorderRadius.circular(10),
        ),
        child: Center(
          child: Text(
            selectedItem?.status ?? '',
            style: const TextStyle(color: Colors.white, fontWeight: FontWeight.w600),
          ),
        ),
      ),
    );
  }
}

