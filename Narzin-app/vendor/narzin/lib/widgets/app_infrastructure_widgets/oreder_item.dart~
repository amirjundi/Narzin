import 'package:flutter/material.dart';
import 'package:narzin/core/constants.dart';
import 'package:narzin/core/screen_sizing_constants.dart';
import 'package:narzin/generated/l10n.dart';
import 'package:narzin/model_layer/order_model.dart';

import '../../generated/assets.dart';

class OrderItem extends StatelessWidget {
  const OrderItem({
    super.key,
    this.orderNumber,
    this.orderItem,
    this.total,
    this.locale,

  });
  final String? orderNumber;
  final List<OrderItemData>? orderItem;

  final String? total;
  final String? locale;

  @override
  Widget build(BuildContext context) {
    return Container(
      margin: const EdgeInsets.only(bottom: 10),
      width: ScreenSizing.width,
      padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 10),
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(10),
        border: Border.all(
          color: Colors.grey[300]!,
        ),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.stretch,
        children: [
          Row(
            mainAxisAlignment: MainAxisAlignment.spaceBetween,
            children: [
              Expanded(child: Text(orderNumber??S.of(context).order_number)),
              const Icon(
                Icons.arrow_forward_ios_rounded,
                size: 15,
              ),
            ],
          ),
          const SizedBox(
            height: 5,
          ),
          Text(
            S.of(context).products,
            textAlign: TextAlign.right,
            style: const TextStyle(fontSize: 13),
          ),
          const SizedBox(
            height: 5,
          ),
          ///////////////////////////////////////////////////////////////////////////
          ListView.builder(
            shrinkWrap: true,
            physics: const NeverScrollableScrollPhysics(),
            itemBuilder: (context, index) {
              String? productName = locale == 'ar'? (orderItem?[index].product?.nameArabic):(orderItem?[index].product?.nameGerman);
              String? quantity = orderItem?[index].quantity.toString();
              String? productPrice = orderItem?[index].subtotal.toString();
              return Column(
                children: [
                  Padding(
                    padding: const EdgeInsets.only(bottom: 8.0),

                    child: Row(
                      children: [
                        Expanded(flex: 2,child: Text(productName??'إسم المنتج'),),
                        SizedBox(width:50,child: Center(child: Text('${quantity??1}x',overflow: TextOverflow.ellipsis,))),
                        SizedBox(width:120,child: Align(alignment: AlignmentDirectional.centerEnd,child: Text('EUR ${(productPrice??'xxx')+''}',overflow: TextOverflow.ellipsis,))),
                      ],
                    ),
                  ),
                  const SizedBox(
                    height: 10,
                  ),
                ],
              );
            },
            itemCount: orderItem?.length??0,
          ),


          Row(
            children: [
              const Text(
                'الإجمالي',
                style: TextStyle(fontWeight: FontWeight.w600),
              ),
              Expanded(
                child: Align(
                  alignment: AlignmentDirectional.centerEnd,
                  child: Text(
                    'EUR ${total??"xxx"}',
                    style: const TextStyle(fontWeight: FontWeight.w600),
                  ),
                ),
              ),
            ],
          ),
          const SizedBox(
            height: 10,
          ),
          Row(
            children: [
              const Row(
                children: [
                  Icon(Icons.access_time_outlined,size: 20,color: Colors.grey,),
                  SizedBox(
                    width: 5,
                  ),
                  Text(
                    'DD/MM - HH:MM',
                    style: TextStyle(fontWeight: FontWeight.w600,fontSize: 10,color: Colors.grey),
                  ),
                ],
              ),
              const Spacer(),
              Row(
                children: [
                  Image.asset(Assets.imagesSuccessPayment1,width: 20,),
                  Text(
                    'الدفع عند الاستلام',
                    style: TextStyle(fontWeight: FontWeight.w600,color: Constants.mainColor),
                  ),
                ],
              ),
            ],
          ),
        ],
      ),
    );
  }
}