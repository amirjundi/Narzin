    if (json['items'] != null) {
      items = <OrderItemData>[];
      json['items'].forEach((v) {
        items!.add(new OrderItemData.fromJson(v));
      });
    }
    user = json['user'] != null ? new User.fromJson(json['user']) : null;
    address =
    json['address'] != null ? new Address.fromJson(json['address']) : null;
    status = json['status'];
  }
