								"exec": [
									"function generateRandomNumber(minLength = 6, maxLength = 12) {",
									"    const length = Math.floor(Math.random() * (maxLength - minLength + 1)) + minLength;",
									"    let number = Math.floor(Math.random() * 9) + 1; // Ensure the first digit is non-zero",
									"",
									"    for (let i = 1; i < length; i++) {",
									"        number = number * 10 + Math.floor(Math.random() * 10);",
									"    }",
									"",
									"    return number.toString();",
									"}",
									"",
									"pm.environment.set('orderId', generateRandomNumber())"
								],
								"type": "text/javascript",
								"packages": {}
