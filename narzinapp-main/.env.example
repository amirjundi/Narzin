APP_NAME=Narzin
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
# For the web SPA cookie auth, the API and web app must share a parent domain.
# Set this to that shared domain in production, e.g. .narzin.com
SESSION_DOMAIN=null
# Required for cross-site cookies in production (must be served over HTTPS):
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax

# ─── Web SPA (Sanctum cookie auth) ─────────────────────
# Comma-separated domains the SPA is served from (no scheme). The web app must
# be on one of these for the session cookie to authenticate API requests.
SANCTUM_STATEFUL_DOMAINS=localhost:3000
# Origins allowed to send credentialed requests (CORS). Must be exact origins,
# never "*", when credentials are enabled.
CORS_ALLOWED_ORIGINS=http://localhost:3000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─── Nass Payment Gateway ───────────────────────────────
NASS_BASE_URL=https://uat-gateway.nass.iq:9746/
NASS_USERNAME=
NASS_PASSWORD=
NASS_BACK_REF=https://narzin.com/thank-you
NASS_NOTIFY_URL=https://admin.narzin.com/api/nass/webhook

# ─── Firebase / FCM ────────────────────────────────────
FCM_PROJECT_ID=narzin-notification
FIREBASE_CREDENTIALS_PATH=

# ─── Mobile App Deep Link ──────────────────────────────
MOBILE_APP_SCHEME=narzin://
